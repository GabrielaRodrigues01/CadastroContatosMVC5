@model CadastroContatosMVC5.Models.ContatoModel

@{
    ViewBag.Title = "Cadastro de Contato";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card-custom">

            <!-- HEADER -->
            <div class="mb-4">
                <h4 class="mb-1">Novo Contato</h4>
                <p class="text-muted small mb-0">
                    Preencha os dados abaixo para cadastrar um novo contato.
                </p>
            </div>

            @using (Html.BeginForm("Index", "Contato", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <!-- NOME -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.Nome, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(m => m.Nome, new { @class = "form-control input-search", placeholder = "Digite o nome" })
                    @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "text-danger small" })
                </div>

                <!-- EMAIL -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control input-search", placeholder = "Digite o e-mail", type = "email" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                </div>

                <!-- TELEFONE -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.Telefone, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(m => m.Telefone, new { @class = "form-control input-search", placeholder = "(11) 99999-9999" })
                    @Html.ValidationMessageFor(m => m.Telefone, "", new { @class = "text-danger small" })
                </div>

                <!-- CIDADE -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.Cidade, new { @class = "form-label fw-semibold" })
                    @Html.TextBoxFor(m => m.Cidade, new { @class = "form-control input-search", placeholder = "Digite a cidade" })
                    @Html.ValidationMessageFor(m => m.Cidade, "", new { @class = "text-danger small" })
                </div>

                <!-- OBSERVAÇÃO -->
                <div class="mb-3">
                    @Html.LabelFor(m => m.Observacao, new { @class = "form-label fw-semibold" })
                    @Html.TextAreaFor(m => m.Observacao, new { @class = "form-control input-search", rows = 4, placeholder = "Digite uma observação" })
                    @Html.ValidationMessageFor(m => m.Observacao, "", new { @class = "text-danger small" })
                </div>

                <!-- BOTÕES -->
                <div class="d-flex justify-content-between mt-4">

                    <button type="reset" class="btn btn-outline-secondary">
                        Limpar
                    </button>

                    <button type="submit" class="btn btn-primary">
                        Salvar contato
                    </button>

                </div>
            }

        </div>

    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}